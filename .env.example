# انسخ هذا الملف باسم .env وضع بيانات الاتصال الخاصة بك

# رابط الاتصال بقاعدة بيانات MongoDB (محلي أو MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/music_games_db

# مثال لو تستخدم MongoDB Atlas (سحابي):
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/music_games_db

# منفذ تشغيل السيرفر
PORT=3000

# رمز الدخول للوحة الأدمن (admin.html) — غيّره لرمز خاص فيك
ADMIN_CODE=your-secret-code-here

# مفتاح سري داخلي لتوقيع جلسة الأدمن (نص عشوائي طويل)
ADMIN_SECRET=change-this-to-any-long-random-text-you-like

# ------------------------------------------------------------------
# تسجيل الدخول بجوجل (لصفحة "اطلب رفع أغنية")
# أنشئ بيانات الاعتماد من Google Cloud Console → APIs & Services → Credentials
# نوع الاعتماد: OAuth Client ID → Web application
# Authorized redirect URI يجب أن يطابق GOOGLE_CALLBACK_URL بالضبط
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# مفتاح سري لتشفير جلسات تسجيل الدخول (نص عشوائي طويل مختلف عن ADMIN_SECRET)
SESSION_SECRET=change-this-to-another-long-random-text
